{% set photo = images_by_id[block.image_id] %}
<table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
  <tr>
    <td>
      <img src="{{ photo.src }}" width="{{ photo.width }}" height="{{ photo.height }}" alt="{{ photo.alt }}" style="display:block;width:100%;max-width:{{ photo.width }}px;height:auto;border-radius:{{ layout.card_radius_px }}px;">
      {% if photo.caption %}<p class="chart-caption">{{ photo.caption }}</p>{% endif %}
    </td>
  </tr>
</table>
