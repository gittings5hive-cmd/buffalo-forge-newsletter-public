<table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
  <tr>
    <td style="padding-left:16px;border-left:3px solid {{ colors_light.accent }};">
      <p class="quote-text">&ldquo;{{ block.text }}&rdquo;</p>
      {% if block.attribution %}<p class="quote-attribution">{{ block.attribution }}</p>{% endif %}
    </td>
  </tr>
</table>
